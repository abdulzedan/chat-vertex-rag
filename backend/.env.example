# =============================================================================
# RAG Engine Demo - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Run ./scripts/setup-gcp.sh to create the required GCP resources.

# -----------------------------------------------------------------------------
# Required - Google Cloud Configuration
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=your-project-id

# IMPORTANT: GCP_LOCATION is for Vertex AI (Gemini models).
# Use a valid Vertex AI region like: us-central1, us-east1, europe-west1
# Do NOT use "global" - that's only for Discovery Engine (handled internally).
GCP_LOCATION=us-central1

# GCS bucket for temporary file staging during uploads
# Created by setup-gcp.sh as: {PROJECT_ID}-rag-temp
GCS_STAGING_BUCKET=your-project-id-rag-temp

# Authentication: Uses Application Default Credentials (ADC) by default
# Run: gcloud auth application-default login
# Only set this if using a service account JSON file instead of ADC:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# -----------------------------------------------------------------------------
# Required - Vertex AI Search (Discovery Engine)
# -----------------------------------------------------------------------------
# These IDs are created by setup-gcp.sh
# Discovery Engine always uses location "global" (hardcoded in backend)
VERTEX_SEARCH_DATASTORE_ID=rag-demo-datastore
VERTEX_SEARCH_APP_ID=rag-demo-app

# -----------------------------------------------------------------------------
# Required - Gemini Model Configuration
# -----------------------------------------------------------------------------
GEMINI_MODEL=gemini-2.5-flash
FALLBACK_MODELS=gemini-1.5-flash,gemini-1.5-pro

# -----------------------------------------------------------------------------
# Optional - Feature Flags
# -----------------------------------------------------------------------------
# Document AI - Enable for advanced PDF processing with table extraction
USE_DOCUMENT_AI=false
DOCAI_LOCATION=us                    # Only needed if USE_DOCUMENT_AI=true
DOCAI_PROCESSOR_ID=                  # Form Parser processor ID (if using Document AI)

# Vertex AI Search enhancements
USE_VERTEX_RANKING=false             # Enable for better search result ranking
USE_VERTEX_GROUNDING=false           # Enable for response validation and fact-checking

# -----------------------------------------------------------------------------
# Optional - V2 Data Store (Native Layout Parsing + Chunking)
# -----------------------------------------------------------------------------
# V2 data store uses Discovery Engine's native document processing:
#   - Layout-based chunking (headings, paragraphs, tables)
#   - Automatic parsing (no Document AI needed)
#   - Chunk search mode with adjacent chunk retrieval
# Created by setup-gcp.sh alongside the V1 data store.
VERTEX_SEARCH_DATASTORE_V2_ID=rag-demo-datastore-v2
VERTEX_SEARCH_APP_V2_ID=rag-demo-app-v2
USE_V2_DATASTORE=true                # Use V2 data store as default for search
USE_STREAM_ANSWER=false              # Use Discovery Engine streamAnswer API for one-call retrieval+generation
